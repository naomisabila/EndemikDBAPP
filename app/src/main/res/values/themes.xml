<resources>
    <!-- Base Theme -->
    <style name="Theme.EndemikDBAPP" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/tertiary</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:textColorPrimary">@android:color/black</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Specific Font Styles - Using system fonts to ensure the app opens -->
    <style name="TextAppearance.Hero" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.CardTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Scientific" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Note" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>
</resources>